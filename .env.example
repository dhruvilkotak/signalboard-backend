# Alpaca Paper Trading (free at alpaca.markets)
ALPACA_API_KEY=your_alpaca_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Anthropic Claude Haiku (platform.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_key_here
ANTHROPIC_MODEL=claude-haiku-4-5

# Firebase Admin SDK (console.firebase.google.com → Project Settings → Service Accounts)
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# SendGrid (free tier, sendgrid.com)
SENDGRID_API_KEY=your_sendgrid_key_here
ALERT_EMAIL_FROM=alerts@yourdomain.com
ALERT_EMAIL_TO=your@email.com

# App config
PORT=8000
ENVIRONMENT=development

# Tickers to track
TICKERS=SPY,VOO,JEPI,JEPQ,SCHD,SGOV,MSFT,AAPL,NVDA,GOOGL,AMZN,META,HOOD

# Signal cache TTL in seconds (refresh only if price moves >1.5%)
SIGNAL_CACHE_TTL=1800
PRICE_CHANGE_THRESHOLD=1.5

# Paper trading budget
PAPER_BUDGET=100.0
